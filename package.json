{
  "name": "stoke",
  "version": "0.2.0",
  "description": "One tool to minimize Claude Code token cost: cache keep-alive proxy + spend monitor + one dashboard.",
  "type": "module",
  "private": true,
  "engines": { "node": ">=20" },
  "license": "MIT",
  "workspaces": ["packages/*"],
  "bin": { "stoke": "packages/cli/bin/stoke.mjs" },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "start": "node packages/cli/bin/stoke.mjs start",
    "status": "node packages/cli/bin/stoke.mjs status",
    "test": "npm run test -ws --if-present",
    "test:proxy": "npm run test -w @stoke/proxy",
    "test:monitor": "npm run test -w @stoke/monitor"
  }
}
