{
  "name": "stoke",
  "version": "0.1.0",
  "description": "TTL-aware keep-alive proxy for the Claude prompt cache. Fires max_tokens:0 pings just before cache TTL so you never pay for a rebuild.",
  "type": "module",
  "engines": { "node": ">=20" },
  "license": "MIT",
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "prompt-caching",
    "proxy",
    "keep-alive",
    "ttl",
    "cli"
  ],
  "homepage": "https://github.com/USERNAME/stoke#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/USERNAME/stoke.git"
  },
  "bugs": {
    "url": "https://github.com/USERNAME/stoke/issues"
  },
  "files": [
    "src",
    "dashboard",
    "demo",
    "scripts",
    "tsconfig.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "tsx src/cli.ts start",
    "status": "tsx src/cli.ts status",
    "tail": "tsx src/cli.ts tail",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0",
    "@opentelemetry/sdk-metrics": "^1.25.0"
  }
}
